@model IReadOnlyList<SecilStoreConfig.Library.Models.ConfigItem>
@{
    ViewData["Title"] = "Configurations";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="h3 mb-0">Configurations</h1>
    <a class="btn btn-primary" asp-action="Create">+ New Configuration</a>
</div>

<div class="mb-3">
    <input id="nameFilter" class="form-control" placeholder="Filter by name..." autocomplete="off" />
</div>

<table class="table table-striped table-hover align-middle">
    <thead>
        <tr>
            <th>Id</th>
            <th>Name</th>
            <th>Type</th>
            <th>Value</th>
            <th>Active</th>
            <th>Application</th>
            <th class="text-end">Actions</th>
        </tr>
    </thead>
    <tbody id="configTable">
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Id</td>
                <td class="config-name">@item.Name</td>
                <td>@item.Type</td>
                <td>@item.Value</td>
                <td>
                    @if (item.IsActive)
                    {
                        <span class="badge bg-success">Active</span>
                    }
                    else
                    {
                        <span class="badge bg-secondary">Inactive</span>
                    }
                </td>
                <td>@item.ApplicationName</td>
                <td class="text-end">
                    <a class="btn btn-sm btn-outline-primary" asp-action="Edit" asp-route-id="@item.Id">Edit</a>
                    <form asp-action="Delete" asp-route-id="@item.Id" method="post" class="d-inline"
                          onsubmit="return confirm('Delete this configuration?');">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="btn btn-sm btn-outline-danger">Delete</button>
                    </form>
                </td>
            </tr>
        }
    </tbody>
</table>
<p id="emptyRow" class="text-muted" style="display:none;">No configurations match your filter.</p>

@section Scripts {
    <script>
        const input = document.getElementById('nameFilter');
        const rows = Array.from(document.querySelectorAll('#configTable tr'));
        const emptyRow = document.getElementById('emptyRow');

        input.addEventListener('input', function () {
            const term = this.value.trim().toLowerCase();
            let visible = 0;
            rows.forEach(row => {
                const name = row.querySelector('.config-name')?.textContent.toLowerCase() ?? '';
                const match = name.includes(term);
                row.style.display = match ? '' : 'none';
                if (match) visible++;
            });
            emptyRow.style.display = visible === 0 ? '' : 'none';
        });
    </script>
}
